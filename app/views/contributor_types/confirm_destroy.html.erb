<section class="app-page">
  <div class="page-header">
    <div>
      <span class="pill-note">Danger zone</span>
      <h1 class="page-title">Delete <%= @contributor_type.name %>?</h1>
      <p class="page-subtitle">Deleting a contributor type can affect how contributors are organised and assigned.</p>
    </div>
  </div>

  <div class="app-card">
    <div class="app-card-body">
      <div class="alert alert-warning mb-4" role="alert">
        This is a second confirmation step. If the type is still in use, deletion will be blocked.
      </div>

      <dl class="row detail-grid mb-0">
        <dt class="col-md-3">Contributor Type</dt>
        <dd class="col-md-9"><%= @contributor_type.name %></dd>

        <dt class="col-md-3">Contributors Using It</dt>
        <dd class="col-md-9"><%= @contributors.size %></dd>
      </dl>
    </div>
  </div>

  <% if @contributors.any? %>
    <div class="app-card">
      <div class="app-card-body">
        <h2 class="h5 mb-3">Contributors currently using this type</h2>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Company</th>
                <th>Key Contact</th>
                <th>Email</th>
              </tr>
            </thead>
            <tbody>
              <% @contributors.each do |contributor| %>
                <tr>
                  <td><%= link_to contributor.company_name, contributor_path(contributor), class: "fw-semibold text-decoration-none" %></td>
                  <td><%= contributor.key_contact.presence || "—" %></td>
                  <td><%= contributor.email.presence || "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

  <div class="stack-actions">
    <%= button_to "Yes, delete this type",
          contributor_type_path(@contributor_type),
          method: :delete,
          class: "btn btn-danger" %>
    <%= link_to "Cancel", contributor_type_path(@contributor_type), class: "btn btn-outline-secondary" %>
  </div>
</section>
