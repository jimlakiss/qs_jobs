<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @document.filename %> - PDF Viewer</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="icon" href="/pdf_viewer/favicon.png">

  <style>
    /* ── Reset & base ───────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #1a1a2e;
      --surface:   #16213e;
      --panel:     #0f3460;
      --accent:    #4da3ff;
      --accent-dk: #2a7de1;
      --text:      #e0e0e0;
      --text-dim:  #9aa0b0;
      --border:    rgba(255,255,255,0.10);
      --border-md: rgba(255,255,255,0.18);
      --ok:        #27ae60;  --ok-bg:   rgba(39,174,96,0.15);
      --warn:      #e67e22;  --warn-bg: rgba(230,126,34,0.15);
      --fail:      #e74c3c;  --fail-bg: rgba(231,76,60,0.15);
      --radius:    6px;
      --font:      system-ui, -apple-system, sans-serif;
      --mono:      'Menlo', 'Consolas', monospace;
    }
    html, body { height: 100%; font-family: var(--font); font-size: 14px; background: var(--bg); color: var(--text); }

    /* ── Layout ─────────────────────────────────────────── */
    #app { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

    /* Top toolbar */
    #toolbar {
      flex: 0 0 auto;
      display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      padding: 8px 14px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      z-index: 10;
    }
    .toolbar-logo {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; font-weight: 600; color: var(--text);
      margin-right: 6px;
    }
    .toolbar-logo img { width: 28px; height: 28px; border-radius: 4px; }
    .toolbar-sep { width: 1px; height: 24px; background: var(--border-md); flex-shrink: 0; }
    .toolbar-label { font-size: 11px; color: var(--text-dim); }

    /* Inputs & selects in toolbar */
    #toolbar input[type="text"],
    #toolbar select {
      background: var(--panel); border: 1px solid var(--border-md);
      color: var(--text); border-radius: var(--radius);
      padding: 4px 8px; font-size: 12px; height: 30px;
    }
    #toolbar input[type="text"]::placeholder { color: var(--text-dim); }
    #toolbar select { cursor: pointer; }

    /* File upload button */
    #file-input { display: none; }
    .upload-btn {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--panel); border: 1px solid var(--border-md);
      color: var(--text); border-radius: var(--radius);
      padding: 5px 12px; font-size: 12px; cursor: pointer; height: 30px;
      transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
    }
    .upload-btn:hover { background: var(--accent-dk); border-color: var(--accent); }
    .upload-btn.is-drag-over {
      background: var(--accent-dk);
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(77,163,255,0.22);
    }
    .upload-hint { color: var(--text-dim); font-size: 11px; }

    /* Action buttons */
    .btn {
      display: inline-flex; align-items: center; gap: 5px;
      border-radius: var(--radius); padding: 5px 12px;
      font-size: 12px; font-family: var(--font); cursor: pointer; height: 30px;
      border: 1px solid var(--border-md); transition: background 0.15s;
    }
    .btn-default { background: var(--panel); color: var(--text); }
    .btn-default:hover { background: #1e4a8a; }
    .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent-dk); font-weight: 600; }
    .btn-primary:hover { background: var(--accent-dk); }
    .btn-split { background: #1a6b3c; color: #fff; border-color: #22854c; font-weight: 600; }
    .btn-split:hover { background: #22854c; }

    /* ── Mode toggle ────────────────────────────────────────── */
    .mode-toggle {
      display: flex; border: 1px solid var(--border-md);
      border-radius: 5px; overflow: hidden; flex-shrink: 0;
    }
    .btn-mode {
      padding: 4px 14px; font-size: 11px; font-weight: 600;
      background: var(--panel); border: none; color: var(--text-dim);
      cursor: pointer; transition: background 0.15s; font-family: var(--font);
    }
    .btn-mode.is-active { background: var(--accent); color: #fff; }

    /* Mode-based visibility */
    .extract-controls { display: contents; }
    #app.mode-measure .extract-controls { display: none; }
    #app.mode-extract #measure-toolbar { display: none; }
    #app.mode-extract #msr-pnl-resizer,
    #app.mode-extract #msr-panel { display: none; }

    /* ── Measure toolbar ────────────────────────────────────── */
    #measure-toolbar {
      flex: 0 0 auto;
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
      padding: 5px 14px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      z-index: 9;
    }
    .btn-tool.is-active,
    .btn-toggle.is-active { background: var(--accent); color: #fff; border-color: var(--accent-dk); }

    /* ── Scale zone dialog ──────────────────────────────────── */
    #sz-backdrop {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.42);
      z-index: 9100;
    }
    #sz-dialog {
      position: fixed; top: 50%; left: 50%;
      transform: translate(-50%,-50%);
      background: var(--surface); border: 1px solid var(--border-md);
      border-radius: var(--radius); padding: 18px 22px;
      z-index: 9101; min-width: 300px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.7);
    }
    #sz-dialog h3 { margin: 0 0 14px; font-size: 14px; font-weight: 600; }
    .sz-tabs { display: flex; gap: 4px; margin-bottom: 14px; }
    .sz-tab {
      font-size: 11px; padding: 4px 10px; cursor: pointer;
      border-radius: 3px; border: 1px solid var(--border-md);
      background: none; color: var(--text-dim); transition: background 0.12s;
    }
    .sz-tab.is-active { background: var(--accent); color: #fff; border-color: var(--accent-dk); }
    .sz-panel { display: none; }
    .sz-panel.is-active { display: block; }
    .sz-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; font-size: 12px; }
    .sz-row label { color: var(--text-dim); white-space: nowrap; }
    .sz-row select, .sz-row input[type="number"] {
      background: var(--panel); border: 1px solid var(--border-md);
      color: var(--text); border-radius: 3px; padding: 3px 6px; font-size: 12px; height: 26px;
    }
    .sz-hint { font-size: 11px; color: var(--text-dim); line-height: 1.5; margin-bottom: 10px; }
    .sz-status { font-size: 12px; color: var(--accent); font-weight: 600; margin-bottom: 8px; min-height: 18px; }
    .sz-foot { display: flex; justify-content: flex-end; gap: 8px; margin-top: 16px; }

    /* ── Measurement SVG styles ─────────────────────────────── */
    /* All clickable SVG shapes default to pointer-events:none so they never
       steal the crosshair cursor from the overlay or swallow mousemove events.
       pointer-events is re-enabled only when the select tool is active
       (overlay gets class "tool-select" from JS). */
    .msr-zone-poly {
      fill: rgba(77,163,255,0.07); stroke: #4da3ff;
      stroke-width: 1.5; stroke-dasharray: 7 4;
      pointer-events: none;
    }
    #overlay.tool-select .msr-zone-poly { pointer-events: visiblePainted; cursor: pointer; }
    .msr-zone-poly.msr-sel { fill: rgba(77,163,255,0.18); stroke-width: 2.5; }
    .msr-zone-lbl { font-size: 11px; fill: #4da3ff; font-family: sans-serif; pointer-events: none; }
    .msr-line { stroke: #f0a040; stroke-width: 2; fill: none; pointer-events: none; }
    .msr-tick { stroke: #f0a040; stroke-width: 2; pointer-events: none; }
    .msr-linear-g { pointer-events: none; }
    #overlay.tool-select .msr-linear-g { pointer-events: visiblePainted; cursor: pointer; }
    #overlay.tool-select .msr-linear-g circle { pointer-events: visiblePainted; cursor: grab; }
    .msr-linear-g.msr-sel .msr-line,
    .msr-linear-g.msr-sel .msr-tick { stroke: #ffd080; stroke-width: 3; }
    .msr-area-poly {
      fill: rgba(240,160,64,0.12); stroke: #f0a040; stroke-width: 2; pointer-events: none;
    }
    #overlay.tool-select .msr-area-poly { pointer-events: visiblePainted; cursor: pointer; }
    .msr-area-poly.msr-sel { fill: rgba(240,160,64,0.28); stroke: #ffd080; stroke-width: 3; }
    .msr-lbl {
      font-size: 12px; fill: #f0a040; font-family: sans-serif; font-weight: 700;
      paint-order: stroke fill;
      stroke: rgba(0,0,0,0.85); stroke-width: 3px;
      pointer-events: none;
    }
    .msr-lbl.msr-sel { fill: #ffd080; }
    .msr-count-dot { fill: #e74c3c; stroke: #fff; stroke-width: 1.5; pointer-events: none; }
    #overlay.tool-select .msr-count-dot { pointer-events: visiblePainted; cursor: pointer; }
    .msr-count-dot.msr-sel { fill: #ff8888; }
    .msr-count-num {
      font-size: 9px; fill: #fff; text-anchor: middle; dominant-baseline: central;
      pointer-events: none; font-weight: 700; font-family: sans-serif;
    }
    .msr-preview {
      stroke: rgba(240,160,64,0.45); stroke-width: 1.5;
      stroke-dasharray: 5 4; fill: none; pointer-events: none;
    }
    .msr-snap-ring { fill: none; stroke: #f0a040; stroke-width: 1.5; stroke-dasharray: 3 3; pointer-events: none; }


    /* Draw type swatch */
    #draw-type-swatch[data-swatch="sheet_id"]          { color: #4da3ff; }
    #draw-type-swatch[data-swatch="description"]        { color: #f39c12; }
    #draw-type-swatch[data-swatch="issue_id"]           { color: #2ecc71; }
    #draw-type-swatch[data-swatch="date"]               { color: #e74c3c; }
    #draw-type-swatch[data-swatch="issue_description"]  { color: #9b59b6; }
    #draw-type-swatch[data-swatch="prepared_by"]        { color: #1abc9c; }
    #draw-type-swatch[data-swatch="project_id"]         { color: #e67e22; }
    #draw-type-swatch { font-size: 11px; font-weight: 700; min-width: 60px; }

    /* ── Main viewer area ───────────────────────────────── */
    #main-body { flex: 1 1 auto; display: flex; overflow: hidden; }

    #sidebar {
      width: 260px; flex: 0 0 260px;
      overflow-y: auto; overflow-x: hidden;
      background: var(--surface);
      border-right: 1px solid var(--border);
      padding: 8px 6px;
      display: flex; flex-direction: column; gap: 6px;
    }
    #sidebar .thumb {
      width: 100%; min-height: 40px;
      flex-shrink: 0;
      cursor: pointer;
      border: 2px solid transparent;
      border-radius: 3px;
      overflow: hidden;
      background: #444;
    }
    #sidebar .thumb img { width: 100%; height: auto; display: block; }

    .sidebar-resizer {
      flex: 0 0 5px;
      background: var(--border);
      cursor: ew-resize;
      transition: background 0.15s;
    }
    .sidebar-resizer:hover,
    .sidebar-resizer.is-resizing { background: var(--accent); }

    #pdf-scroll {
      flex: 1 1 auto;
      overflow: auto;
      background: #111;
    }
    #canvas-outer { display: inline-block; vertical-align: top; }
    #canvas-wrap  { position: relative; display: inline-block; }
    #pdf-canvas  { display: block; }
    #overlay {
      position: absolute; top: 0; left: 0;
      cursor: crosshair; overflow: visible;
    }

    /* SVG region colours — must match pdf_viewer.js swatch mapping */
    #overlay rect                             { fill: rgba(77,163,255,0.15); stroke: #4da3ff; stroke-width: 2; }
    #overlay rect[data-type="description"]    { fill: rgba(243,156,18,0.15); stroke: #f39c12; }
    #overlay rect[data-type="issue_id"]       { fill: rgba(46,204,113,0.15); stroke: #2ecc71; }
    #overlay rect[data-type="date"]           { fill: rgba(231,76,60,0.15);  stroke: #e74c3c; }
    #overlay rect[data-type="issue_description"] { fill: rgba(155,89,182,0.15); stroke: #9b59b6; }
    #overlay rect[data-type="prepared_by"]    { fill: rgba(26,188,156,0.15); stroke: #1abc9c; }
    #overlay rect[data-type="project_id"]     { fill: rgba(230,126,34,0.15); stroke: #e67e22; }
    #overlay rect.selected                    { stroke-width: 3; filter: brightness(1.3); }

    /* ── Processing overlay ─────────────────────────────── */
    #processing-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.72);
      display: flex; align-items: center; justify-content: center;
      z-index: 9000; font-family: var(--font);
    }
    .proc-box {
      background: var(--surface); border: 1px solid var(--border-md);
      border-radius: 10px; padding: 28px 44px;
      font-size: 16px; font-weight: 500; color: var(--text);
    }

    /* ────────────────────────────────────────────────────────────────────
       STAGING PANEL
       Sits as a fixed overlay above the main viewer.
    ──────────────────────────────────────────────────────────────────── */
    #staging-panel {
      display: none;
      position: fixed; inset: 0;
      background: rgba(10,10,20,0.82);
      z-index: 8000;
      align-items: center; justify-content: center;
      padding: 20px;
    }
    .sp-container {
      background: var(--surface);
      border: 1px solid var(--border-md);
      border-radius: 10px;
      width: 100%; max-width: 1080px;
      max-height: 90vh;
      display: flex; flex-direction: column;
      overflow: hidden;
    }

    /* Header row */
    .sp-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .sp-header h2 { font-size: 15px; font-weight: 600; }
    .sp-header .sp-meta { font-size: 12px; color: var(--text-dim); }

    /* Toolbar row */
    .sp-toolbar {
      display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      padding: 10px 20px;
      border-bottom: 1px solid var(--border);
      background: var(--bg);
      flex-shrink: 0;
    }
    .sp-toolbar label { font-size: 12px; color: var(--text-dim); }
    .sp-toolbar select,
    .sp-toolbar input[type="text"] {
      background: var(--panel); border: 1px solid var(--border-md);
      color: var(--text); border-radius: var(--radius);
      padding: 4px 8px; font-size: 12px; height: 28px;
    }
    .sp-toolbar select { cursor: pointer; }
    #sp-custom-row { display: none; align-items: center; gap: 8px; }
    #sp-custom-input { width: 280px; font-family: var(--mono); font-size: 11px; }
    .sp-export-name-row { display: flex; align-items: center; gap: 8px; min-width: min(100%, 360px); }
    #sp-export-name { width: 260px; font-family: var(--mono); font-size: 11px; }

    /* Table scroll area */
    .sp-scroll { flex: 1 1 auto; overflow-y: auto; overflow-x: auto; }

    table.sp-table {
      width: 100%; border-collapse: collapse; font-size: 13px;
    }
    table.sp-table thead th {
      position: sticky; top: 0;
      background: var(--panel);
      padding: 8px 10px;
      text-align: left; font-weight: 500; font-size: 11px;
      color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.04em;
      border-bottom: 1px solid var(--border-md);
    }
    table.sp-table tbody tr { border-bottom: 1px solid var(--border); }
    table.sp-table tbody tr:last-child { border-bottom: none; }
    table.sp-table tbody tr:hover { background: rgba(255,255,255,0.03); }
    table.sp-table tbody tr.sp-row-warn { background: var(--warn-bg); }
    table.sp-table tbody tr.sp-row-fail { background: var(--fail-bg); }
    table.sp-table td { padding: 6px 10px; vertical-align: middle; }

    .sp-td-check  { width: 32px; text-align: center; }
    .sp-td-pg     { width: 36px; font-size: 11px; color: var(--text-dim); text-align: center; }
    .sp-td-rev    { width: 80px; }
    .sp-td-status { width: 90px; }

    .sp-cell {
      width: 100%; background: transparent;
      border: 1px solid transparent; border-radius: 4px;
      color: var(--text); font-size: 13px; font-family: var(--font);
      padding: 3px 6px;
    }
    .sp-cell:hover { border-color: var(--border-md); background: var(--panel); }
    .sp-cell:focus { outline: none; border-color: var(--accent); background: var(--panel); }
    .sp-cell::placeholder { color: var(--text-dim); }

    .sp-preview {
      font-family: var(--mono); font-size: 11px;
      color: var(--text-dim);
      display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      max-width: 280px;
    }

    .sp-badge {
      display: inline-block; font-size: 11px; font-weight: 600;
      padding: 2px 9px; border-radius: 999px;
    }
    .sp-ok   { background: var(--ok-bg);   color: var(--ok);   }
    .sp-warn { background: var(--warn-bg); color: var(--warn); }
    .sp-fail { background: var(--fail-bg); color: var(--fail); }

    /* Footer row */
    .sp-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 20px; flex-wrap: wrap; gap: 10px;
      border-top: 1px solid var(--border);
      background: var(--bg);
      flex-shrink: 0;
    }
    #sp-stats { font-size: 12px; color: var(--text-dim); }
    .sp-actions { display: flex; gap: 8px; flex-wrap: wrap; }

    .sp-btn {
      display: inline-flex; align-items: center; gap: 5px;
      border-radius: var(--radius); padding: 7px 14px;
      font-size: 12px; font-family: var(--font); cursor: pointer; font-weight: 500;
      border: 1px solid var(--border-md); transition: background 0.15s;
    }
    .sp-btn-ghost  { background: transparent; color: var(--text); }
    .sp-btn-ghost:hover  { background: var(--panel); }
    .sp-btn-csv    { background: var(--panel); color: #f39c12; border-color: rgba(243,156,18,0.4); }
    .sp-btn-csv:hover   { background: rgba(243,156,18,0.15); }
    .sp-btn-json   { background: var(--panel); color: #9b59b6; border-color: rgba(155,89,182,0.4); }
    .sp-btn-json:hover  { background: rgba(155,89,182,0.15); }
    .sp-btn-zip    { background: #1a6b3c; color: #fff; border-color: #22854c; font-weight: 700; }
    .sp-btn-zip:hover  { background: #22854c; }

    /* ── Drag-and-drop row reordering ───────────────────── */
    .sp-drag-handle {
      cursor: grab; color: var(--text-dim);
      padding: 0 6px; font-size: 16px; line-height: 1;
      user-select: none; -webkit-user-select: none;
    }
    .sp-drag-handle:hover { color: var(--text); }
    tr[draggable="true"]:active .sp-drag-handle { cursor: grabbing; }

    tr.sp-dragging { opacity: 0.35; background: var(--panel) !important; }

    /* Insertion line — shows above or below the target row */
    tr.sp-drop-above td { border-top: 2px solid var(--accent) !important; }
    tr.sp-drop-below td { border-bottom: 2px solid var(--accent) !important; }

    /* Sequence number toggle */
    .sp-seq-toggle {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12px; color: var(--text-dim); cursor: pointer;
    }
    .sp-seq-toggle input[type="checkbox"] { cursor: pointer; }
    .sp-seq-on { color: var(--accent); font-weight: 600; }

    /* Seq prefix badge in filename preview */
    .sp-seq-prefix { color: var(--accent); font-weight: 700; }

    /* ── Measurement info pane ──────────────────────────────── */
    .msr-pnl-resizer {
      flex: 0 0 5px; background: var(--border); cursor: ew-resize; transition: background 0.15s;
    }
    .msr-pnl-resizer:hover,
    .msr-pnl-resizer.is-resizing { background: var(--accent); }
    #msr-panel {
      width: 220px; flex: 0 0 220px;
      display: flex; flex-direction: column;
      background: var(--surface); border-left: 1px solid var(--border);
      overflow: hidden;
    }
    .msr-pnl-head {
      padding: 7px 10px; font-size: 11px; font-weight: 600;
      color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05em;
      border-bottom: 1px solid var(--border); flex-shrink: 0;
    }
    #msr-pnl-list { flex: 1 1 auto; overflow-y: auto; padding: 4px 4px 8px; }
    .msr-pnl-section {
      font-size: 10px; color: var(--text-dim); text-transform: uppercase;
      letter-spacing: 0.05em; padding: 8px 6px 3px;
    }
    .msr-pnl-row {
      display: flex; align-items: center; gap: 5px;
      padding: 4px 5px; border-radius: 4px; cursor: pointer;
      border: 1px solid transparent; margin-bottom: 1px;
    }
    .msr-pnl-row:hover { background: rgba(255,255,255,0.04); }
    .msr-pnl-row.is-sel { background: rgba(77,163,255,0.12); border-color: rgba(77,163,255,0.28); }
    .msr-pnl-row.msr-pnl-sub { padding-left: 18px; }
    .msr-pnl-icon { font-size: 12px; flex-shrink: 0; width: 16px; text-align: center; }
    .msr-pnl-name {
      flex: 1 1 auto; min-width: 0;
      background: none; border: none; color: var(--text);
      font-size: 11px; font-family: var(--font); padding: 1px 3px; border-radius: 2px;
    }
    .msr-pnl-name:focus { background: var(--panel); outline: 1px solid var(--accent); }
    .msr-pnl-name::placeholder { color: var(--text-dim); }
    .msr-pnl-val { font-size: 10px; color: var(--text-dim); white-space: nowrap; flex-shrink: 0; }
    .msr-pnl-del {
      width: 17px; height: 17px; padding: 0; border: none; background: none;
      color: var(--text-dim); cursor: pointer; border-radius: 3px;
      font-size: 13px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .msr-pnl-del:hover { background: var(--fail-bg); color: var(--fail); }
    .msr-pnl-empty { font-size: 11px; color: var(--text-dim); padding: 12px 8px; line-height: 1.5; }
    /* Snap indicator colour */
    .msr-snap-dot { pointer-events: none; }
  </style>
</head>

<body>
<div id="app" class="mode-extract">

  <!-- ── TOP TOOLBAR ─────────────────────────────────────────── -->
  <div id="toolbar">

    <div class="toolbar-logo">
      <img src="/pdf_viewer/favicon.png" alt="">
      CD iQs — PDF Viewer
    </div>

    <div class="toolbar-sep"></div>

    <a class="btn btn-default" href="<%= project_path(@project) %>">Back to project</a>

    <div class="toolbar-sep"></div>

    <!-- Mode toggle -->
    <div class="mode-toggle">
      <button id="btn-mode-extract" class="btn-mode is-active">Extract</button>
      <button id="btn-mode-measure" class="btn-mode">Measure</button>
    </div>

    <div class="toolbar-sep"></div>

    <!-- File upload -->
    <input type="file" id="file-input" accept=".pdf" multiple>
    <label for="file-input" class="upload-btn" id="upload-drop-zone">
      ↑ Upload PDF(s) <span class="upload-hint">or drop</span>
    </label>
    <span class="toolbar-label">bound or loose</span>

    <div class="toolbar-sep"></div>

    <!-- Document-level fields -->
    <input type="text" id="prepared-by"  placeholder="Prepared by" style="width:130px">
    <input type="text" id="project-id"   placeholder="Project ID"  style="width:110px">

    <!-- Extract-only controls (hidden in Measure mode) -->
    <div class="extract-controls">
      <div class="toolbar-sep"></div>

      <!-- Region type selector -->
      <label class="toolbar-label">Region:</label>
      <select id="region-type" style="width:150px"></select>
      <span id="draw-type-swatch">■</span>

      <div class="toolbar-sep"></div>

      <!-- Extract (document fields only) -->
      <button class="btn btn-default" onclick="extractAll()">Extract fields</button>

      <!-- Split & Name — the main new action -->
      <button class="btn btn-split" id="btn-split-name">✦ Split &amp; Name</button>

      <div class="toolbar-sep"></div>

      <!-- Legacy exports (raw data, not manifest) -->
      <button class="btn btn-default" onclick="downloadJSON()">JSON (raw)</button>
      <button class="btn btn-default" onclick="downloadCSV()">CSV (raw)</button>

      <div class="toolbar-sep"></div>
    </div>

    <!-- Page navigation -->
    <button id="prev-page" class="btn btn-default" style="width:28px;padding:0;justify-content:center" title="Previous page">‹</button>
    <input type="text" id="page-input" style="width:36px;text-align:center" value="—" title="Page number">
    <span style="font-size:12px;color:var(--text-dim)">/ <span id="page-total">—</span></span>
    <button id="next-page" class="btn btn-default" style="width:28px;padding:0;justify-content:center" title="Next page">›</button>
    <span id="page-size-lbl" style="font-size:11px;color:var(--text-dim);white-space:nowrap"></span>

    <div class="toolbar-sep"></div>

    <!-- Zoom controls -->
    <button id="zoom-out" class="btn btn-default" style="width:28px;padding:0;justify-content:center" title="Zoom out">−</button>
    <input type="text" id="zoom-input" style="width:54px;text-align:center" value="—" title="Zoom %">
    <button id="zoom-in"  class="btn btn-default" style="width:28px;padding:0;justify-content:center" title="Zoom in">+</button>

    <div class="toolbar-sep"></div>

    <button id="fit-width" class="btn btn-default" style="padding:0 8px;font-size:11px" title="Fit to window width">Fit Width</button>

    <div class="toolbar-sep"></div>

    <span class="toolbar-label" title="Screen pixels per physical inch — increase if pages appear too small at 100%">DPI</span>
    <input type="number" id="screen-dpi-input" min="72" max="600" step="1"
           style="width:52px;text-align:center"
           title="Screen DPI — 96 = CSS standard. Increase for HiDPI/Retina displays. Typical MacBook: 110–130.">

    <div class="toolbar-sep"></div>

    <button id="tool-snap-toggle" class="btn btn-default btn-toggle is-active"
            title="Toggle vector snapping for region drawing and measurements">⌖ Snap</button>
  </div>

  <!-- ── MEASURE TOOLBAR ──────────────────────────────────────── -->
  <div id="measure-toolbar">
    <span class="toolbar-label">Tool:</span>
    <button id="tool-select"     class="btn btn-default btn-tool is-active" title="Select / pan">Select</button>
    <div class="toolbar-sep"></div>
    <span class="toolbar-label">Measure:</span>
    <button id="tool-scale-zone" class="btn btn-default btn-tool" title="Draw a scale zone polygon">⊞ Scale Zone</button>
    <select id="scale-zone-shape" title="Scale zone drawing shape" style="width:92px;height:30px;font-size:11px">
      <option value="polygon">Polyline</option>
      <option value="rectangle">Rectangle</option>
    </select>
    <button id="tool-linear"     class="btn btn-default btn-tool" title="Linear distance — click 2 points">↔ Linear</button>
    <button id="tool-area"       class="btn btn-default btn-tool" title="Measure area — click polygon, click first point to close">⬡ Area</button>
    <button id="tool-count"      class="btn btn-default btn-tool" title="Count items — click to place numbered markers">⊕ Count</button>
    <div class="toolbar-sep"></div>
    <span id="active-scale-lbl" style="font-size:11px;color:var(--text-dim)">No scale set</span>
    <div class="toolbar-sep"></div>
    <button id="tool-snap-debug" class="btn btn-default btn-tool" title="Show all cached snap points as dots — use to verify snap is aligned to PDF geometry" style="font-size:11px;opacity:0.7">⊙ Snap pts</button>
    <div class="toolbar-sep"></div>
    <span id="snap-status-lbl" style="font-size:11px;color:var(--text-dim);min-width:100px;white-space:nowrap">– No snap</span>
    <div style="flex:1"></div>
    <button id="clear-measurements" class="btn btn-default" style="font-size:11px">Clear Measurements</button>
  </div>

  <!-- ── MAIN BODY ──────────────────────────────────────────── -->
  <div id="main-body">

    <!-- Thumbnail sidebar -->
    <div id="sidebar"></div>
    <div class="sidebar-resizer" id="sidebar-resizer"></div>

    <!-- PDF canvas + SVG overlay -->
    <div id="pdf-scroll">
      <div id="canvas-outer">
        <div id="canvas-wrap">
          <canvas id="pdf-canvas"></canvas>
          <svg id="overlay"></svg>
        </div>
      </div>
    </div>

    <!-- Measurement info pane -->
    <div class="msr-pnl-resizer" id="msr-pnl-resizer"></div>
    <div id="msr-panel">
      <div class="msr-pnl-head">Measurements</div>
      <div id="msr-pnl-list"></div>
    </div>

  </div><!-- /#main-body -->

</div><!-- /#app -->

<!-- ── SCALE ZONE DIALOG ─────────────────────────────────────── -->
<div id="sz-backdrop" hidden></div>
<div id="sz-dialog" hidden>
  <h3>Set Scale Zone</h3>
  <div class="sz-tabs">
    <button class="sz-tab is-active" id="sz-tab-ratio">Scale Ratio</button>
    <button class="sz-tab"           id="sz-tab-ref">Reference Line</button>
  </div>

  <!-- Ratio panel -->
  <div id="sz-panel-ratio" class="sz-panel is-active">
    <div class="sz-row">
      <label>Drawing scale:</label>
      <span style="font-size:13px;font-weight:600">1 :</span>
      <select id="sz-ratio-sel" style="width:100px">
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="5">5</option>
        <option value="10">10</option>
        <option value="20">20</option>
        <option value="25">25</option>
        <option value="50">50</option>
        <option value="100" selected>100</option>
        <option value="200">200</option>
        <option value="250">250</option>
        <option value="500">500</option>
        <option value="1000">1 000</option>
        <option value="1250">1 250</option>
        <option value="2500">2 500</option>
        <option value="custom">Custom…</option>
      </select>
      <input id="sz-ratio-custom" type="number" placeholder="e.g. 75"
             step="any" min="0.01" style="width:70px;display:none">
    </div>
  </div>

  <!-- Reference line panel -->
  <div id="sz-panel-ref" class="sz-panel">
    <p class="sz-hint">Click two points on the PDF over a dimension of known length, then enter the real-world distance.</p>
    <div id="sz-ref-status" class="sz-status">Click first point on the PDF…</div>
    <div id="sz-ref-len-row" class="sz-row" style="display:none">
      <label>Real-world length:</label>
      <input id="sz-ref-len" type="number" placeholder="0.000" step="0.001" min="0.001" style="width:90px">
      <span style="font-size:12px">m</span>
    </div>
  </div>

  <div class="sz-foot">
    <button id="sz-cancel" class="btn btn-default">Cancel</button>
    <button id="sz-ok"     class="btn btn-primary">OK</button>
  </div>
</div>

<!-- ── STAGING PANEL (overlay) ──────────────────────────────── -->
<div id="staging-panel">
  <div class="sp-container">

    <!-- Header -->
    <div class="sp-header">
      <h2>Staging area — review &amp; edit filenames</h2>
      <span class="sp-meta">—</span>
    </div>

    <!-- Controls toolbar -->
    <div class="sp-toolbar">
      <label>Template:</label>
      <select id="sp-template-select" style="width:280px"></select>

      <div id="sp-custom-row">
        <label>Custom:</label>
        <input type="text" id="sp-custom-input" placeholder="{sheet_id} - {description} - {issue_id}">
        <span style="font-size:11px;color:#9aa0b0;">tokens: {sheet_id} {description} {issue_id} {date} {issue_description} {project_id}</span>
      </div>

      <div class="sp-export-name-row">
        <label for="sp-export-name">Export name:</label>
        <input type="text" id="sp-export-name" placeholder="YYMMDD_project_id">
      </div>

      <div style="margin-left:auto;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">

        <!-- Sequence prefix toggle -->
        <label class="sp-seq-toggle" title="Prefix each filename with 001, 002… to force CostX import order">
          <input type="checkbox" id="sp-seq-toggle" checked>
          <span id="sp-seq-label" class="sp-seq-on">Sequence prefix</span>
        </label>

        <!-- Separator for sequence prefix -->
        <span id="sp-seq-sep-row" style="display:flex;align-items:center;gap:6px;">
          <label style="font-size:12px;color:var(--text-dim)">Sep:</label>
          <select id="sp-seq-sep" style="width:60px">
            <option value=" - "> - </option>
            <option value="_">_</option>
          </select>
        </span>

        <!-- Reset order -->
        <button class="sp-btn sp-btn-ghost" id="sp-btn-reset" title="Restore original page number order" style="font-size:11px">↺ Reset order</button>

        <label>Show:</label>
        <select id="sp-filter-select" style="width:130px">
          <option value="all">All sheets</option>
          <option value="issues">Needs review</option>
          <option value="ready">Ready only</option>
        </select>
        <button class="sp-btn sp-btn-ghost" id="sp-btn-close">✕ Close</button>
      </div>
    </div>

    <!-- Scrollable table -->
    <div class="sp-scroll">
      <table class="sp-table">
        <thead>
          <tr>
            <th style="width:28px"></th><!-- drag handle -->
            <th class="sp-td-check">
              <input type="checkbox" id="sp-select-all" checked title="Select / deselect all">
            </th>
            <th class="sp-td-pg">Pg</th>
            <th style="width:100px">Sheet ID</th>
            <th>Description</th>
            <th class="sp-td-rev">Revision</th>
            <th>Filename</th>
            <th class="sp-td-status">Status</th>
          </tr>
        </thead>
        <tbody id="sp-tbody">
          <tr>
            <td colspan="7" style="text-align:center;padding:32px;color:var(--text-dim)">
              Upload a PDF and click <strong>✦ Split &amp; Name</strong> to extract and stage filenames.
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Footer actions -->
    <div class="sp-footer">
      <span id="sp-stats" style="font-size:12px;color:var(--text-dim)">—</span>
      <div class="sp-actions">
        <button class="sp-btn sp-btn-csv"  id="sp-btn-csv">  ⬇ Export CSV</button>
        <button class="sp-btn sp-btn-json" id="sp-btn-json"> ⬇ Export JSON</button>
        <button class="sp-btn sp-btn-zip"  id="sp-btn-zip">  Download ZIP (—)</button>
      </div>
    </div>

  </div>
</div><!-- /#staging-panel -->


<!-- ── SCRIPTS ───────────────────────────────────────────────── -->
<!--  Load order matters: pdf.js → tesseract → pdf-lib → jszip → viewer → splitter  -->

<script>
  window.qsJobsDocument = {
    projectId: <%= @project.id.to_json %>,
    documentId: <%= @document.id.to_json %>,
    projectUrl: <%= project_path(@project).to_json.html_safe %>,
    initialPdfUrl: <%= rails_blob_path(@document, disposition: "inline").to_json.html_safe %>,
    initialPdfName: <%= @document.filename.to_s.to_json.html_safe %>,
    saveExtractionUrl: <%= save_extraction_project_document_path(@project, @document).to_json.html_safe %>,
    uploadExportUrl: <%= upload_export_project_document_path(@project, @document).to_json.html_safe %>,
    csrfToken: <%= form_authenticity_token.to_json.html_safe %>
  };
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script src="https://unpkg.com/tesseract.js@5.0.4/dist/tesseract.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<script src="/pdf_viewer/pdf_viewer.js"></script>
<script src="/pdf_viewer/pdf_splitter.js"></script>

<!-- Snap diagnostic HUD — fixed corner overlay, independent of SVG -->
<div id="snap-hud" style="
  display:none; position:fixed; bottom:16px; right:16px;
  background:rgba(10,10,30,0.92); color:#fff;
  font-family:monospace; font-size:13px; line-height:1.5;
  padding:10px 14px; border-radius:8px; z-index:99999;
  pointer-events:none; border:2px solid #333; min-width:180px;">
  <div id="snap-hud-pts" style="color:#888; font-size:11px;">Snap pts: building…</div>
  <div id="snap-hud-state" style="font-size:15px; font-weight:bold; margin-top:2px;">─</div>
</div>

</body>
</html>
