<section class="app-page">
  <div class="page-header">
    <div>
      <span class="pill-note">Project detail</span>
      <h1 class="page-title"><%= @project.code.presence || "Project" %></h1>
      <p class="page-subtitle"><%= @project.description.presence || "No description has been added for this project yet." %></p>
    </div>

    <div class="stack-actions">
      <%= link_to "Edit Project", edit_project_path(@project), class: "btn btn-primary" %>
      <%= link_to "Back to Projects", projects_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <div class="app-card">
    <div class="app-card-body">
      <dl class="row detail-grid mb-0">
        <dt class="col-md-3">Date</dt>
        <dd class="col-md-9"><%= @project.date&.strftime("%d %b %Y") || "—" %></dd>

        <dt class="col-md-3">Address</dt>
        <dd class="col-md-9"><%= @project.address.presence || "—" %></dd>

        <dt class="col-md-3">Job Value</dt>
        <dd class="col-md-9"><%= @project.job_value ? number_to_currency(@project.job_value) : "—" %></dd>

        <dt class="col-md-3">Fee Value</dt>
        <dd class="col-md-9"><%= @project.fee_value ? number_to_currency(@project.fee_value) : "—" %></dd>

        <dt class="col-md-3">Owner</dt>
        <dd class="col-md-9"><%= @project.project_contributors.find { |pc| pc.role == "Owner" }&.contributor&.company_name || "—" %></dd>
      </dl>
    </div>
  </div>

  <div class="app-card">
    <div class="app-card-body">
      <div class="section-title">
        <h2 class="h4">Assigned Contributors</h2>
      </div>

      <% if @project.project_contributors.any? %>
        <div class="role-grid">
          <% @project.project_contributors.each do |pc| %>
            <div class="role-card">
              <div class="text-muted small mb-1"><%= pc.role.humanize %></div>
              <div class="fw-semibold"><%= pc.contributor.company_name %></div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted mb-0">No contributors have been linked to this project yet.</p>
      <% end %>
    </div>
  </div>

  <div class="stack-actions">
    <%= button_to "Delete Project",
          project_path(@project),
          method: :delete,
          data: { confirm: "Are you sure you want to delete this project?" },
          class: "btn btn-danger" %>
  </div>
</section>
