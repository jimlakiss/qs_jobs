<div class="app-card form-shell">
  <div class="app-card-body">
    <%= form_with model: @contributor do |f| %>
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :contributor_type_id, "Contributor Type", class: "form-label" %>
          <%= f.collection_select :contributor_type_id,
                ContributorType.order(:name),
                :id, :name,
                { include_blank: "Select a type" },
                class: "form-select" %>
        </div>

        <div class="col-md-6">
          <%= f.label :company_name, class: "form-label" %>
          <%= f.text_field :company_name, class: "form-control", placeholder: "Business or consultant name" %>
        </div>

        <div class="col-md-6">
          <%= f.label :key_contact, class: "form-label" %>
          <%= f.text_field :key_contact, class: "form-control", placeholder: "Primary contact" %>
        </div>

        <div class="col-md-6">
          <%= f.label :phone_number, class: "form-label" %>
          <%= f.text_field :phone_number, class: "form-control" %>
        </div>

        <div class="col-md-6">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, class: "form-control" %>
        </div>

        <div class="col-md-6">
          <%= f.label :url, "Website", class: "form-label" %>
          <%= f.url_field :url, class: "form-control", placeholder: "https://example.com" %>
        </div>

        <div class="col-12">
          <%= f.label :address, class: "form-label" %>
          <%= f.text_area :address, class: "form-control", rows: 2 %>
        </div>

        <div class="col-12">
          <%= f.label :notes, class: "form-label" %>
          <%= f.text_area :notes, class: "form-control", rows: 4, placeholder: "Anything the team should know about this contributor" %>
        </div>
      </div>

      <div class="stack-actions mt-4">
        <%= f.submit class: "btn btn-primary" %>
        <%= link_to "Cancel", @contributor.persisted? ? contributor_path(@contributor) : contributors_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>
